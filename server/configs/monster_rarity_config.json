      "normal": 1,
      "champion": 3,
      "rare": 5,
      "super_unique": 8
    },
    "floor_budgets": [
      { "max_floor": 2,  "base": 6,  "per_enemy": 1.0 },
      { "max_floor": 4,  "base": 8,  "per_enemy": 1.5 },
      { "max_floor": 6,  "base": 10, "per_enemy": 2.0 },
      { "max_floor": 8,  "base": 12, "per_enemy": 2.0 },
      { "max_floor": 99, "base": 15, "per_enemy": 2.5 }
