  "spawn_chances": {
    "_comment": "Chance per eligible spawn point to upgrade from Normal. Floor bonuses stack additively.",
    "champion_base_chance": 0.04,
    "rare_base_chance": 0.02,
    "floor_bonus_per_level": 0.01,
    "boss_tiles_never_upgrade": true,
    "max_enhanced_per_room": 2,
    "min_floor_for_champions": 2,
    "min_floor_for_rares": 4,

    "floor_overrides": [
      {
        "_comment": "Floors 1-3: Only 1 enhanced mob per room, rares get 1-2 affixes and 1 minion",
        "max_floor": 3,
        "max_enhanced_per_room": 1,
        "max_rare_minions": 1,
        "rare_affix_count": [1, 2]
      },
      {
        "_comment": "Floors 4-5: Normal enhanced cap, rares get exactly 2 affixes and up to 2 minions",
        "max_floor": 5,
        "max_enhanced_per_room": 2,
        "max_rare_minions": 2,
        "rare_affix_count": [2, 2]
      }
    ]
  },

  "difficulty_budget": {
    "_comment": "Per-room difficulty point budget constraining how much rarity can stack. Budget = base + (per_enemy × enemy_count). Rarity upgrades are downgraded if they exceed the remaining budget.",
