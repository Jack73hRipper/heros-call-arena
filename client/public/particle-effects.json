      "effect": "buff-aura-armor",
      "follow": true,
      "yOffset": 0,
      "buff_id_overrides": {
        "war_cry":        { "effect": "buff-aura-war-cry" },
        "shield_of_faith": { "effect": "buff-aura-armor" },
        "bulwark":        { "effect": "buff-aura-bulwark" },
