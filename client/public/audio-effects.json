{
  "_version": 2,
  "_description": "Maps game events to sound effects. Edit this file to change which sounds play — no code changes needed. Mirrors particle-effects.json pattern.",
  "_instructions": {
    "adding_sounds": "1) Place audio file in client/public/audio/<category>/  2) Add a key→path entry to _soundFiles below  3) Reference the key in the appropriate section  4) AudioManager preloads everything in _soundFiles on init.",
    "key_format": "Each mapping has: key (single sound), variants (array — picks random), volume (0-1), pitchVariance (0-0.2 = ±%)",
    "unmapped_keys": "Any key referenced in combat/skills/etc that has no _soundFiles entry is silently skipped — no errors."
  },

